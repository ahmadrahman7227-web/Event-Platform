generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUM
//////////////////////

enum Role {
  CUSTOMER
  ORGANIZER
}

enum CouponType {
  REFERRAL
  EVENT
}

enum TransactionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

//////////////////////
// USER
//////////////////////

model User {
  id           String @id @default(uuid())
  email        String @unique
  password     String
  role         Role   @default(CUSTOMER)
  referralCode String @unique

  // 🔥 TAMBAHAN WAJIB (FIX FRONTEND)
  points Int @default(0)

  // REFERRAL
  referredBy String?
  referrer   User?   @relation("UserReferral", fields: [referredBy], references: [id], onDelete: SetNull)
  referrals  User[]  @relation("UserReferral")

  // 🔥 CLOUDINARY
  profileImage   String?
  profileImageId String?

  // RESET PASSWORD
  resetToken    String?
  resetTokenExp DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS
  events         Event[]        @relation("EventOrganizer")
  transactions   Transaction[]
  pointHistories PointHistory[]
  coupons        Coupon[]

  referralsMade Referral[] @relation("Referrer")
  referralsUsed Referral[] @relation("Referred")

  @@index([referredBy])
  @@index([email])
  @@index([createdAt]) // 🔥 PERFORMANCE
}

//////////////////////
// REFERRAL
//////////////////////

model Referral {
  id             String @id @default(uuid())
  referrerId     String
  referredUserId String

  createdAt DateTime @default(now())

  referrer     User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User @relation("Referred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredUserId])
}

//////////////////////
// POINT HISTORY
//////////////////////

model PointHistory {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

//////////////////////
// COUPON
//////////////////////

model Coupon {
  id        String   @id @default(uuid())
  code      String   @unique
  discount  Int
  userId    String
  expiresAt DateTime
  isUsed    Boolean  @default(false)

  type CouponType @default(REFERRAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([expiresAt])
}

//////////////////////
// EVENT
//////////////////////

model Event {
  id             String @id @default(uuid())
  title          String
  description    String
  location       String
  price          Int
  availableSeats Int

  // 🔥 CLOUDINARY EVENT IMAGE
  image   String?
  imageId String?

  startDate DateTime
  endDate   DateTime

  organizerId String
  organizer   User @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]

  @@index([organizerId])
  @@index([startDate])
  @@index([createdAt]) // 🔥 PERFORMANCE
}

//////////////////////
// TRANSACTION
//////////////////////

model Transaction {
  id      String @id @default(uuid())
  userId  String
  eventId String

  // 🔥 PAYMENT PROOF
  paymentProof   String?
  paymentProofId String?

  quantity   Int
  totalPrice Int

  usedPoints Int     @default(0)
  couponId   String?

  status TransactionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  coupon Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventId])
  @@index([couponId])
  @@index([status])
  @@index([createdAt]) // 🔥 PERFORMANCE
}
